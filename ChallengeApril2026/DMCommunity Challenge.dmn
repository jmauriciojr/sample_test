  <dmn:decision id="_0F04BA40-3A8F-4DFA-851E-7A02E09A1F89" name="Creatinine Clearance">
    <dmn:extensionElements />
    <dmn:variable id="_AE84EC02-E4FF-49E5-B9C3-D2024224BE4D" name="Creatinine Clearance" typeRef="number" />
    <dmn:informationRequirement id="_C263D11C-3FF6-4FFE-B89E-3F6BAE43D4AB">
      <dmn:requiredInput href="#_37F196A0-C6F1-4F18-A712-8A0EA060EBF8" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_531CD5D7-EF43-4A46-8A78-3AC7CB1EEF3E">
      <dmn:requiredInput href="#_1AA2C0DE-962D-4EF9-A9E6-959CFCB09D0E" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_38A67614-097E-4284-ABE6-285CF81915CF">
      <dmn:requiredInput href="#_3D4D091B-6E2F-4BEE-9D46-21EB37176EE6" />
    </dmn:informationRequirement>
    <dmn:literalExpression id="_DA5884B8-3B71-484F-97C3-8BDD8856CF11">
      <dmn:text>decimal(((140 - Age) * Weight) / (Creatinine Level * 72), 2)</dmn:text>
    </dmn:literalExpression>
  </dmn:decision>
