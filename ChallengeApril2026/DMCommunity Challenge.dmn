  <dmn:decision id="_9674AC14-6D66-4549-B98C-509B0ADA66FA" name="Drug Interaction Warnings">
    <dmn:extensionElements />
    <dmn:variable id="_76D49494-0348-4487-994C-ED6485C48DBC" name="Drug Interaction Warnings" typeRef="Any" />
    <dmn:informationRequirement id="_00718DA5-C347-40BA-8BE8-D4ADB58506B1">
      <dmn:requiredDecision href="#_66B7E093-4C1B-4446-8F1C-326BEFDA3C46" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_8BFE2287-10F2-4B10-BE77-0FB87A9DDB34">
      <dmn:requiredInput href="#_CFE809AA-CCA6-4B55-BC7F-2EF250633EF8" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_94485588-0480-479B-98E6-2E4D79ABAD1B">
      <dmn:requiredDecision href="#_7A6BC865-0AD0-47BB-8813-FD2703251274" />
    </dmn:informationRequirement>
    <dmn:literalExpression id="_F8AE6823-3C09-43DA-979F-36CDD36EAB1A">
      <dmn:text>(for conflict in Conflicting Medications return if list contains(split(Active Medications, &quot;,&quot;), conflict.Medication2) then {ConflictingDrug: conflict.Medication2, Interaction: conflict.Interaction, Risk: conflict.Risk} else null)[item != null]</dmn:text>
    </dmn:literalExpression>
  </dmn:decision>
